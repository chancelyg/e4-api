# e4-api 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 优先级：显式环境变量 > .env > config.yaml > 内置默认值

# 服务器配置（部署期建议放 .env）
E4_SERVER_HOST=127.0.0.1
E4_SERVER_PORT=8080
E4_SERVER_MODE=release

# 数据库配置（如果数据目录与开发不同，放 .env）
E4_DATABASE_DSN=./data/app.db

# 认证配置（敏感，必须放 .env 或外部环境变量）
E4_AUTH_USERNAME=replace-with-admin-name
E4_AUTH_PASSWORD=replace-with-bcrypt-hash
E4_AUTH_SECRET=replace-with-long-random-secret

# 二步验证（可选，敏感，建议放 .env）
# 设置TOTP密钥（Base32格式），如不需要2FA则留空
E4_AUTH_TOTP_SECRET=

# 登录安全设置（可按环境调整）
# 15 分钟窗口内最大登录尝试次数
E4_AUTH_RATE_LIMIT=5
# 登录失败锁定时间（分钟）
E4_AUTH_LOCKOUT_MINUTES=15

# 站点配置（非敏感，也可放 config.yaml）
E4_SITE_TITLE=e4-api
