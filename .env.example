# e4-api 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 服务器配置
E4_SERVER_PORT=8080
E4_SERVER_MODE=release

# 数据库配置
E4_DATABASE_DSN=./data/app.db

# 认证配置
E4_AUTH_USERNAME=admin
E4_AUTH_PASSWORD=$2a$10$4ZPgUj01QYUd/4feVvRWKebBpHeWiHJQyJABYlTcycO6LiguI.Du2
E4_AUTH_SECRET=your-secret-key-change-in-production

# 二步验证（可选）
# 设置TOTP密钥（Base32格式），如不需要2FA则留空
E4_AUTH_TOTP_SECRET=

# 登录安全设置
# 每分钟最大登录尝试次数
E4_AUTH_RATE_LIMIT=5
# 登录失败锁定时间（分钟）
E4_AUTH_LOCKOUT_MINUTES=15

# 站点配置
E4_SITE_TITLE=e4-api